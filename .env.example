# --- Binance symbols (comma-separated; default = all 7 below) ---
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,HYPEUSDT,BNBUSDT

# Polymarket slugs per symbol (JSON) or legacy single BTC slug
PM_MARKET_SLUG=btc-updown-5m
PM_MARKET_SLUGS={"BTCUSDT":"btc-updown-5m","ETHUSDT":"","SOLUSDT":""}

# Or explicit YES token ids per symbol
# PM_YES_TOKEN_ID_BTCUSDT=
# PM_YES_TOKEN_IDS={"BTCUSDT":"..."}

LOG_OUT_TEMPLATE=/opt/alpha-trader/output/logs/market_%Y-%m-%d.jsonl
HEALTH_FILE=/opt/alpha-trader/output/health/logger.json
LOGGER_INTERVAL_MS=250
LOG_LEVEL=INFO

# Phase 6 only
PM_API_KEY=
PM_API_SECRET=
PM_PASSPHRASE=
PM_PRIVATE_KEY=
POLYGON_RPC_URL=
